@using GoodHamburger.BlazorWASM.Orders.Services
@using GoodHamburger.BlazorWASM.Shared.Enumerators
@using GoodHamburger.DataTransfer.Orders.Responses

@inject OrderService OrderService

<div class="card shadow-sm main-card">
    <div class="fw-bold my-2 h4 card-title">
        Total de Pedidos
    </div>
    <div class="fw-bold mt-2 mb-3 h3 card-main-value">
        @orderSummary?.TotalOrders
    </div>
    <div class="d-flex justify-content-center gap-2 flex-wrap order-filters my-2">
        <button type="button"
                class="order-filter @(selectedFilter == OrderTimelineFilterEnum.Today ? "active-filter" : "")"
                @onclick="() => SelectFilter(OrderTimelineFilterEnum.Today)">
            Hoje
        </button>
        <button type="button"
                class="order-filter @(selectedFilter == OrderTimelineFilterEnum.Week ? "active-filter" : "")"
                @onclick="() => SelectFilter(OrderTimelineFilterEnum.Week)">
            7 dias
        </button>
        <button type="button" 
                class="order-filter @(selectedFilter == OrderTimelineFilterEnum.Month ? "active-filter" : "")"
                @onclick="() => SelectFilter(OrderTimelineFilterEnum.Month)">
            30 dias
        </button>
        <button type="button"
                class="order-filter @(selectedFilter == OrderTimelineFilterEnum.AllTime ? "active-filter" : "")"
                @onclick="() => SelectFilter(OrderTimelineFilterEnum.AllTime)">
            Todos os tempos
        </button>
    </div>
    <div class="card-information-block mt-2 mb-3">
        <div class="d-flex align-items-center card-information flex-wrap my-3 m-2 fw-bold">
            <div class="icon-total-value mx-2">
                <i class="bi bi-coin"></i>
            </div>
            <div class="text-total-value">
                Valor total sem descontos
            </div>
            <div class="currency-total-value mx-2 ms-auto">
                @orderSummary?.SubtotalAmount.ToString("C")
            </div>
        </div>
        <div class="d-flex align-items-center card-information flex-wrap my-3 m-2 fw-bold">
            <div class="icon-total-value mx-2">
                <i class="bi bi-coin"></i>
            </div>
            <div class="text-total-value fw-bold">
                Valor total de descontos
            </div>
            <div class="currency-total-value mx-2 ms-auto">
                @orderSummary?.TotalDiscount.ToString("C")
            </div>
        </div>
        <div class="d-flex align-items-center card-information flex-wrap my-3 m-2 fw-bold">
            <div class="icon-total-value mx-2">
                <i class="bi bi-coin"></i>
            </div>
            <div class="text-total-value">
                Valor total final
            </div>
            <div class="currency-total-value mx-2 ms-auto">
                @orderSummary?.TotalAmount.ToString("C")
            </div>
        </div>
    </div>
</div>

@code {
    private OrderTimelineFilterEnum selectedFilter = OrderTimelineFilterEnum.Today;
    private OrderSummaryResponse? orderSummary;

    protected override async Task OnInitializedAsync()
    {
        await SelectFilter(selectedFilter);
    }

    private async Task SelectFilter(OrderTimelineFilterEnum filter)
    {
        selectedFilter = filter;
        await GetSummaryAsync(filter, CancellationToken.None);
    }

    private async Task GetSummaryAsync(OrderTimelineFilterEnum filterEnum, CancellationToken cancellationToken) =>
        orderSummary = await OrderService.GetSummaryAsync((int)filterEnum, cancellationToken);
}
