@using GoodHamburger.BlazorWASM.Orders.Services
@using GoodHamburger.DataTransfer.Orders.DTOs

@inject OrderService OrderService;
@inject NavigationManager Navigation;

<div class="card shadow-md mb-2 h-100">
    <div class="order-items my-2 mx-3">
        <label class="form-label fw-bold">4. Resumo do Pedido</label>
    </div>
    <div class="d-flex subtotal-amount my-2 mx-3">
        <span class="fw-bold">Subtotal</span>
        <span class="ms-auto">@((ValidatedOrder?.Order.Subtotal ?? 0).ToString("C"))</span>
    </div>
    <div class="d-flex discount-amount my-2 mx-3">
        <span class="fw-bold">Descontos</span>
        <span class="ms-auto">@((ValidatedOrder?.Order.Discount ?? 0).ToString("C"))</span>
    </div>

    <hr class="w-90 mx-auto border-3">
    <div class="d-flex total-amount my-2 mx-3">
        <span class="fw-bold h5">Valor</span>
        <span class="ms-auto">@((ValidatedOrder?.Order?.Subtotal ?? 0).ToString("C"))</span>
    </div>
    <hr class="w-90 mx-auto border-3">

    <button type="button" class="m-3 btn-submit-order" @onclick="() => InsertOrderAsync()">
        <i class="bi bi-check-circle"></i>
        Finalizar Pedido
    </button>

    <button type="button" class="mx-3 btn-clean-order">
        <i class="bi bi-trash"></i>
        Limpar Pedido
    </button>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mx-2 mt-3">
            @errorMessage
        </div>
    }
</div>


@code {
    [Parameter] public ValidateOrderDto ValidatedOrder { get; set; } = null!;

    private string? errorMessage;

    private async Task InsertOrderAsync()
    {
        try
        {
            errorMessage = null;
            await OrderService.InsertAsync(ValidatedOrder, CancellationToken.None);
            Navigation.NavigateTo("/");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}